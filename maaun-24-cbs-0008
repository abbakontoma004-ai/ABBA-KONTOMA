# Step 1: Setup the quiz data
quiz = [
    {
        "question": "What is 2 + 2?",
        "options": ["1", "2", "3", "4"],
        "correct_answer": "4"
    },
    {
        "question": "What is the capital of France?",
        "options": ["Berlin", "Paris", "London", "Madrid"],
        "correct_answer": "Paris"
    },
    {
        "question": "Which keyword is used to define a function in Python?",
        "options": ["func", "define", "def", "function"],
        "correct_answer": "def"
    }
]

# Step 3 & 4: Loop through questions, interact, and evaluate
score = 0
for question_dict in quiz:
    print("\n" + question_dict["question"])  # Newline for separation
    
    # Display options numbered
    for i, option in enumerate(question_dict["options"], start=1):
        print(f"{i}. {option}")
    
    user_answer = input("Enter your answer (e.g., 'Paris' or '4'): ")
    
    if user_answer == question_dict["correct_answer"]:
        print("Correct!")
        score += 1
    else:
        print(f"Wrong! The correct answer was {question_dict['correct_answer']}.")

# Step 5: Calculate and output results
def calculate_percentage(score, total_questions):
    return (score / total_questions) * 100

total_questions = len(quiz)
percentage = calculate_percentage(score, total_questions)

print(f"\nQuiz complete! You scored {score}/{total_questions} ({percentage:.2f}%).")

# Personal message
if percentage >= 80:
    print("Excellent work! You're a quiz master.")
elif percentage >= 50:
    print("Good effort! Keep practicing.")
else:
    print("Don't worry – try again to improve!")
